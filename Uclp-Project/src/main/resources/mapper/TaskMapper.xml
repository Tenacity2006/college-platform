<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kevin.mapper.TaskMapper">

    <!-- 结果映射保持不变 -->
    <resultMap id="TaskMap" type="com.kevin.pojo.Task">
        <id property="id" column="id"/>
        <result property="publisherId" column="publisher_id"/>
        <result property="acceptorId" column="acceptor_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="detail" column="detail"/>
        <result property="detailFile" column="detail_file"/>
        <result property="reward" column="reward"/>
        <result property="deadline" column="deadline"/>
        <result property="status" column="status"/>
        <result property="proof" column="proof"/>
        <result property="createtime" column="create_time"/>
        <result property="updatetime" column="update_time"/>
    </resultMap>

    <!-- 1. 发布任务 -->
    <insert id="publish" parameterType="com.kevin.pojo.Task" useGeneratedKeys="true" keyProperty="id">
        insert into task (
            publisher_id,
            category_id,
            detail,
        <if test="detailFile != null">
            detail_file,
        </if>
            reward,
            deadline,
            status,          -- 强制初始化为 0
            acceptor_id,     -- 强制初始化为 NULL
            proof,           -- 强制初始化为 NULL
            create_time,
            update_time
        ) values (
                     #{publisherId},
                     #{categoryId},
                     #{detail},
        <if test="detailFile != null">
             #{detailFile},
        </if>
                     #{reward},
                     #{deadline},
                     0,               -- 对应 STATUS_PENDING
                     NULL,
                     NULL,
                     NOW(),
                     NOW()
                 )
    </insert>

    <!-- 2. 根据 ID 查询  -->
    <select id="selectById" resultMap="TaskMap">
        select * from task where id = #{id}
    </select>

    <!-- 3. 根据发布者 ID 查询列表  -->
    <select id="selectMyPublishedListById" resultMap="TaskMap" parameterType="java.lang.Integer">
        select * from task
        where publisher_id = #{publisherId}
        order by create_time desc
    </select>

    <!-- 4. 更新任务  -->
    <update id="updateById" parameterType="com.kevin.pojo.Task">
        update task
        <set>
            <if test="categoryId != null">
                category_id = #{categoryId},
            </if>

            <if test="detail != null">
                detail = #{detail},
            </if>

            <if test="detailFile != null">
                detail_file = #{detailFile},
            </if>

            <if test="reward != null">
                reward = #{reward},
            </if>

            <if test="deadline != null">
                deadline = #{deadline},
            </if>

            update_time = NOW()
        </set>
        where id = #{id}
    </update>

    <!-- 5. 删除任务 -->
    <delete id="deleteById">
        delete from task where id = #{id}
    </delete>


    <!-- 6. 查询公共任务 (只查待接单) -->
    <select id="selectPublicTasks" resultMap="TaskMap">
        select * from task
        where status = #{status}
        <if test="categoryId != null">
            and category_id = #{categoryId}
        </if>
        order by create_time desc
    </select>


    <!-- 7. 查询我接的任务 -->
    <select id="selectByAcceptorId" resultMap="TaskMap">
        select *
        from task
        where acceptor_id = #{acceptorId}
        and status in (1, 2)
        order by
        case when status = 1 then 0 else 1 end,
        update_time desc
    </select>


    <!-- 8. 接单  -->
    <update id="accept" parameterType="com.kevin.pojo.Task">
        update task
        set
            status = 1,
            acceptor_id = #{acceptorId},
            update_time = NOW()
        where id = #{id}
          and status = 0
          and acceptor_id is null
    </update>

    <!-- 9. 取消接单 -->
    <update id="cancelAccept" parameterType="com.kevin.pojo.Task">
        update task
        set
            status = 0,
            acceptor_id = null,
            update_time = NOW()
        where id = #{id}
          and status = 1
    </update>

    <!-- 10. 完成任务 -->
    <update id="completeTask" parameterType="com.kevin.pojo.Task">
        update task
        <set>
            <if test="task.status != null">
                status = #{task.status},
            </if>
            <if test="task.proof != null">
            proof = #{task.proof},
            </if>
            update_time = NOW()
        </set>
        where id = #{task.id}
        and acceptor_id = #{acceptorId}
    </update>

</mapper>